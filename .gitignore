########################################
# Malware samples
########################################
# Never commit real malware samples

samples/
payloads/
infected/
quarantine/

# Executables and installers
*.exe
*.dll
*.scr
*.msi
*.com

# Only exclude suspicious script payloads
samples/**/*.ps1
payloads/**/*.ps1


